# Unity standard lfs
# https://docs.unity3d.com/Manual/GitCookbook.html

# Documentation
*.pdf diff=astextplain
*.doc diff=astextplain
*.docx diff=astextplain
*.rtf diff=astextplain

# Binary assets
*.png filter=lfs diff=lfs merge=lfs -text
