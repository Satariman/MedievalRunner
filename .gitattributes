# Line endings
# Set default behavior to automatically normalize line endings
* text=auto

# Force LF for scripts
*.cs text eol=lf
*.cginc text eol=lf
*.shader text eol=lf
*.hlsl text eol=lf
*.asmdef text eol=lf
*.inputactions text eol=lf

# Игнорировать сторонние библиотеки в статистике языков
"Assets/TextMesh Pro/**" linguist-vendored
"Assets/TutorialInfo/**" linguist-vendored
"Assets/Settings/**" linguist-vendored
"Assets/Samples/**" linguist-vendored